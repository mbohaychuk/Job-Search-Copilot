# Database
DATABASE_URL=postgresql+asyncpg://jsc:devpassword@localhost:5432/jsc
POSTGRES_PASSWORD=devpassword

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Ranking weights (must sum to 1.0)
WEIGHT_SEMANTIC=0.40
WEIGHT_SKILL_COVERAGE=0.25
WEIGHT_TITLE_MATCH=0.15
WEIGHT_SENIORITY=0.10
WEIGHT_LOCATION=0.10

# Ingestion
INGESTION_RATE_LIMIT_DELAY=1.0
INGESTION_MAX_CONCURRENT=3
INGESTION_PLAYWRIGHT_ENABLED=false

# Target locations
TARGET_LOCATIONS=["Edmonton","Calgary"]
